@article{blundellWeightUncertaintyNeural2015,
  title = {Weight {{Uncertainty}} in {{Neural Networks}}},
  author = {Blundell, Charles and Cornebise, Julien and Kavukcuoglu, Koray and Wierstra, Daan},
  date = {2015},
  doi = {10.48550/arXiv.1505.05424},
  abstract = {We introduce a new, efficient, principled and backpropagation-compatible algorithm for learning a probability distribution on the weights of a neural network, called Bayes by Backprop. It regularises the weights by minimising a compression cost, known as the variational free energy or the expected lower bound on the marginal likelihood. We show that this principled kind of regularisation yields comparable performance to dropout on MNIST classification. We then demonstrate how the learnt uncertainty in the weights can be used to improve generalisation in non-linear regression problems, and how this weight uncertainty can be used to drive the exploration-exploitation trade-off in reinforcement learning. In Proceedings of the 32nd International Conference on Machine Learning (ICML 2015)}
}

@book{chenEvaluationProbabilisticElectricity2024,
  title = {Evaluation of {{Probabilistic Electricity Demand Forecasts}}},
  author = {Chen, Hongjia and Mohammad, Asaad and Totsuka, Tetsuya and Laliashvili, Ani and Navarro, Maria},
  date = {2024-06-24},
  doi = {10.1109/PMAPS61648.2024.10667185},
  abstract = {As the electricity landscape undergoes transformative shifts with the rising prevalence of photovoltaic (PV) systems and the growing stochastic nature of electricity consumption from electric vehicles (EVs), the significance of accurate probabilistic forecasting becomes paramount. This paper explores and evaluates key metrics employed in assessing probabilistic load forecasts in the energy industry. The study explores the Probability Integral Transform (PIT), Chi-square test, Pinball loss function, and Continuous Ranked Probability Score (CRPS), elucidating their significance and practical applications. Through a comprehensive case study analyzing probabilistic forecasts by the Australian Electricity Market Operator (AEMO) and TESLA, the paper demonstrates the strengths and weaknesses of each metric. The analysis emphasizes the critical need for examining these metrics at a granular level, offering insights into their performance across distinct trading periods and first assessing forecast reliability before delving into considerations of forecast sharpness.},
  keywords = {Bayesian LSTM},
  file = {C:\Users\lhaus\Zotero\storage\DJA3CBWX\Chen et al. - 2024 - Evaluation of Probabilistic Electricity Demand Forecasts.pdf}
}

